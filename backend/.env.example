NODE_ENV=development
PORT=5000
AUTH_DB_URI=mongodb://localhost:27017/AuthDB
AUDIT_DB_URI=mongodb://localhost:27017/AuditDB
USER_DB_URI=mongodb://localhost:27017/UserDB
ROOM_DB_URI=mongodb://localhost:27017/RoomDB
BOOKING_DB_URI=mongodb://localhost:27017/BookingDB
REVIEW_DB_URI=mongodb://localhost:27017/ReviewDB
PAYMENT_DB_URI=mongodb://localhost:27017/PaymentDB
PAYMENT_CURRENCY=VND
JWT_SECRET=your_jwt_secret_key_change_this
JWT_EXPIRE=15m
REFRESH_TOKEN_SECRET=your_refresh_token_secret_key_change_this
REFRESH_TOKEN_EXPIRE=7d
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GMAIL_USER=your_email@gmail.com
GMAIL_PASSWORD=your_app_password
OTP_EXPIRY=5m
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000
SWAGGER_ENABLED=true
